{
  "name": "faithlog-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --host lan",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"App.tsx\" \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "eas-build-pre-install": "node scripts/prepare-firebase-config.js",
    "hooks:install": "sh scripts/install-git-hooks.sh",
    "hooks:validate:branch": "node scripts/validate-branch-name.js",
    "hooks:validate:commit": "node scripts/validate-commit-message.js"
  },
  "dependencies": {
    "expo": "~56.0.0",
    "expo-secure-store": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "~19.2.3",
    "babel-preset-expo": "^56.0.15",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
