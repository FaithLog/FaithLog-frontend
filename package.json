{
  "name": "faithlog-frontend",
  "version": "0.2.1",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --host lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"App.tsx\" \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "eas-build-pre-install": "node scripts/prepare-firebase-config.js",
    "hooks:install": "sh scripts/install-git-hooks.sh",
    "hooks:validate:branch": "node scripts/validate-branch-name.js",
    "hooks:validate:commit": "node scripts/validate-commit-message.js"
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "./node_modules"
      ]
    }
  },
  "dependencies": {
    "@react-native-firebase/analytics": "25.1.0",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/crashlytics": "25.1.0",
    "@react-native-firebase/messaging": "^25.1.0",
    "@react-native-firebase/remote-config": "^25.1.0",
    "expo": "~56.0.15",
    "expo-application": "~56.0.3",
    "expo-build-properties": "~56.0.22",
    "expo-clipboard": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.21",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "~19.2.3",
    "@types/react-test-renderer": "19.1.0",
    "babel-preset-expo": "^56.0.15",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
