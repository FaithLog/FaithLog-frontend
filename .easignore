# macOS
.DS_Store

# Git metadata / local repo helpers
.git
.git/
.github/
.githooks/

# dependencies
node_modules/

# Expo / React Native local output
.eas/
.expo/
.expo-shared/
dist/
web-build/

# Expo prebuild / local native projects
# EAS builds regenerate these from app.config.js.
android/
ios/

# local Codex/Git recovery artifacts
.codex
.codex/**
.codex-artifacts
.codex-artifacts/**
.git.dataless-backup-*
.git/worktrees.broken-*
.harness
.harness/**

# Docs, planning, QA reports, and store screenshots are not required by EAS.
*.md
docs/
agent.md

# Docker/local deployment files are unrelated to native app builds.
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# Firebase native config files are restored from EAS environment variables.
google-services.json
GoogleService-Info.plist

# signing and provisioning material
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Native build output
*.aab
*.apk
*.ipa
android/.gradle/
android/app/build/
android/build/
ios/Pods/
ios/build/

# Metro / bundler
.metro-cache/
.cache/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
firebase-debug.log*
*.log

# environment
.env
.env.*
!.env.example

# test / coverage
coverage/
**/*.test.ts
**/*.test.tsx
**/*.test.js
**/*.test.jsx
**/*.test.mjs
**/*.spec.ts
**/*.spec.tsx
**/*.spec.js
**/*.spec.jsx
**/*.spec.mjs
**/__tests__/
**/__mocks__/
vitest.config.*
eslint.config.*

# QA screenshots and store-submission captures
docs/qa/
*.apns

# Accidental duplicate local copies
scripts/* 2.*
**/* 2.*

# TypeScript
*.tsbuildinfo

# IDE
.idea/
.vscode/
!.vscode/extensions.json
